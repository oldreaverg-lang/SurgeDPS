# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/

# Secrets — cover every .env variant anywhere in the tree (root, ui/, src/,
# scripts/, whatever). .env.example is the only exception so templates can
# still be committed. Also block stray private keys / credential files.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
*.pem
*.key
secrets/
credentials.json

# Node
ui/node_modules/
ui/dist/

# Generated / cache
tmp_integration/

# OS
.DS_Store
Thumbs.db

# Lock files (Office temp)
.~lock.*

# Excel / Word artifacts
*.xlsx
*.docx
.cache/
